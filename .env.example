# ============================================================================
# webPage_infra .env — Quelle der Wahrheit für den gesamten Stack.
# Verschlüsselte Variante: .env.gpg (siehe README "Secrets / .env.gpg").
# Generieren der Supabase-Server-Secrets: openssl rand -base64 32  (bzw. -hex 32)
# ============================================================================

# ─── Docker Hub ──────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=dein_dockerhub_username

# ─── Cloudflare Tunnel ──────────────────────────────────────────────────────
# CLOUDFLARE_TUNNEL_TOKEN und CLOUDFLARE_TUNNEL_ID werden NICHT mehr hier (oder in
# .env.gpg) gepflegt. Der Bootstrap (cf_ensure_tunnel_if_token) erzeugt pro VPS
# einen eigenen Tunnel ("brewing-<hostname>") via Cloudflare-API und schreibt
# Token + ID in die LOKALE .env dieses VPS. Nie committen.
# (CLOUDFLARE_TUNNEL_ID kann bei Bedarf lokal als manueller Override gesetzt werden.)

# Cloudflare API für scripts/cloudflare-reconcile.sh (Tunnel anlegen + Hostnames + DNS
# + Cloudflare Access-App für portainer.alexstuder.cloud automatisch absichern).
# Scope: Account › Cloudflare Tunnel › Edit  (legt Tunnel an + Ingress schreiben)
#        Zone › DNS › Edit                    (CNAMEs anlegen/ändern/löschen)
#        Zone › Zone › Read                   (Zone-Auflösung)
#        Account › Access: Apps and Policies › Edit
#                                             (Access-App + Allow-Policy für portainer. anlegen)
# "Cloudflare Tunnel: Edit" deckt sowohl CREATE (POST cfd_tunnel) als auch
# Ingress-Reconcile (PUT .../configurations) ab — kein separater Scope nötig.
# Der Access-Scope wird nur auf dem Hub-VPS (PORTAINER_ROLE=hub) aktiv genutzt;
# auf allen anderen VPS erzeugt er keinen API-Call.
# Diese drei Werte gehören in .env.gpg (geteilt über alle VPS derselben Zone).
# Token-Setup: siehe README.md → "Cloudflare API-Token".
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# CLOUDFLARE_TUNNEL_NAME: optionaler Override für den Tunnel-Namen.
# Default = "brewing-<sanitisierter hostname>" (abgeleitet via hostnamectl --static).
# Nur setzen wenn der Hostname nicht eindeutig/stabil ist.
CLOUDFLARE_TUNNEL_NAME=

# ─── Cloudflare R2 (Off-site-Backups) ──────────────────────────────────────
# Ziel für scripts/backup.sh (verschlüsselte .fc.gpg-Dumps). R2 ist S3-kompatibel.
# Variante A: ein Ordner pro App/Service im Bucket (_supabase_core/,
# brew_assistent/, rapt_dashboard/) — backup.sh legt sie an.
# Token-Setup: Cloudflare Dashboard → R2 → "Manage R2 API Tokens" → Object-RW
# auf den Bucket scopen. Account-ID steht auf der R2-Übersichtsseite.
# Endpoint entweder voll als R2_ENDPOINT setzen ODER nur R2_ACCOUNT_ID
# (Script leitet https://<account>.r2.cloudflarestorage.com daraus ab).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=backup

# ─── External APIs ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# RAPT und Brewfather haben KEINE globalen Credentials mehr: beide sind rein per-User
# (rapt.user_profiles / vault, RPCs get_my_brewfather_creds). Nichts hier eintragen.

# =============================================================================
# ─── brew_assistent-Stack — DB/Auth-Secrets ──────────────────────────────────
# =============================================================================
# Generierung: brew_assistent-new/scripts/generate-supabase-secrets.sh
# ANON_KEY + SERVICE_ROLE_KEY: HS256-JWTs signiert mit ASSISTENT_JWT_SECRET.
ASSISTENT_POSTGRES_PASSWORD=<openssl rand -base64 32>
ASSISTENT_JWT_SECRET=<openssl rand -base64 64>
ASSISTENT_ANON_KEY=<HS256-JWT mit role=anon, signiert mit ASSISTENT_JWT_SECRET>
ASSISTENT_SERVICE_ROLE_KEY=<HS256-JWT mit role=service_role, signiert mit ASSISTENT_JWT_SECRET>

# URLs für den brew_assistent-Stack (GoTrue + Flutter-App + Proxy):
ASSISTENT_PUBLIC_URL=https://db-assistent.alexstuder.cloud
# TODO DEFERRED: Cloudflare-Tunnel-Route db-assistent.<domain> → kong-assistent:8000 anlegen.
#   Lokal: http://localhost:54321
ASSISTENT_SITE_URL=https://assistent.alexstuder.cloud
ASSISTENT_ADDITIONAL_REDIRECT_URLS=

# Supabase interne URL (api_proxy_assistent → kong-assistent im selben assistent_net):
# Phase 3: jetzt per-Proxy-Var; SUPABASE_INTERNAL_URL entfällt aus Proxy-Kontext.
# SUPABASE_INTERNAL_URL=http://kong-assistent:8000

# =============================================================================
# ─── rapt_dashboard-Stack — DB/Auth-Secrets ──────────────────────────────────
# =============================================================================
# Zweites Secret-Set (getrennte auth.users, getrennte DB).
# Generierung: openssl rand + python3 JWT-Signing (analog assistent-Stack).
# ANON_KEY + SERVICE_ROLE_KEY: HS256-JWTs signiert mit RAPT_JWT_SECRET.
RAPT_POSTGRES_PASSWORD=<openssl rand -base64 32>
RAPT_JWT_SECRET=<openssl rand -base64 64>
RAPT_ANON_KEY=<HS256-JWT mit role=anon, signiert mit RAPT_JWT_SECRET>
RAPT_SERVICE_ROLE_KEY=<HS256-JWT mit role=service_role, signiert mit RAPT_JWT_SECRET>

# proxy_sync NUR in der rapt-DB (db-sync schreibt nur rapt — Konzept §3).
# MUSS sich von RAPT_POSTGRES_PASSWORD unterscheiden — least-privilege.
RAPT_PROXY_SYNC_PASSWORD=<openssl rand -base64 32>

# URLs für den rapt_dashboard-Stack (GoTrue + Flutter-App):
RAPT_PUBLIC_URL=https://db-rapt.alexstuder.cloud
# TODO DEFERRED: Cloudflare-Tunnel-Route db-rapt.<domain> → kong-rapt:8000 anlegen.
#   Lokal: http://localhost:54331
RAPT_SITE_URL=https://rapt.alexstuder.cloud
RAPT_ADDITIONAL_REDIRECT_URLS=

# ─── Proxy-Split Phase 3 (2026-05-25) + SSO Phase 5 (2026-05-25) ────────────
# Zwei Container aus EINEM brew_proxy-Image (PROXY_ROLE=assistent|rapt).
# GHA-Build bleibt unverändert: ein Image, zwei Compose-Services.
#
# SSO_SIGNING_SECRET: geteiltes HMAC-HS256-Secret für REST-Föderations-Tickets (Phase 5).
# assistent-Proxy signiert Tickets damit; rapt-Proxy verifiziert sie.
# BEIDE Proxy-Container erhalten diesen Wert via env_file: .env (kein explizites Durchreichen nötig).
# Eigenständiges Geheimnis — KEIN wiederverwendetes JWT_SECRET/ANON_KEY (eigener Blast-Radius).
# Generierung: openssl rand -base64 48
SSO_SIGNING_SECRET=<openssl rand -base64 48>
#
# assistent-Proxy (api_proxy_assistent, Port 8083 lokal):
#   SUPABASE_INTERNAL_URL → kong-assistent:8000 (assistent_net).
#   OPENAI_API_KEY kommt via env_file: .env.
#   KEIN DATABASE_URL — kein db-sync in dieser Rolle.
ASSISTENT_PROXY_SUPABASE_URL=http://kong-assistent:8000
ASSISTENT_PROXY_CORS_ORIGIN=
# Prod: ASSISTENT_PROXY_CORS_ORIGIN=https://aibrewgenius.alexstuder.cloud
#
# rapt-Proxy (api_proxy_rapt, Port 8085 lokal):
#   SUPABASE_INTERNAL_URL → kong-rapt:8000 (rapt_net).
#   DATABASE_URL → proxy_sync@db-rapt (db-sync schreibt nur rapt).
RAPT_PROXY_SUPABASE_URL=http://kong-rapt:8000
RAPT_PROXY_CORS_ORIGIN=
# Prod: RAPT_PROXY_CORS_ORIGIN=https://rapt.alexstuder.cloud
#
# RAPT_PROXY_DATABASE_URL: vollständige Conn-String — KEIN ${VAR} einsetzen.
# (cicd-Lesson 2026-05-24: Compose-Default-Expressions werden literalisch aufgelöst.)
#
# Single-VPS (Container-zu-Container via rapt_net):
#   RAPT_PROXY_DATABASE_URL=postgres://proxy_sync:DEIN_RAPT_PROXY_SYNC_PASSWORD@db-rapt:5432/postgres?sslmode=disable
# Cross-VPS (Proxy auf anderem VPS, rapt-DB über Cloudflare-Tunnel):
#   RAPT_PROXY_DATABASE_URL=postgres://proxy_sync:DEIN_RAPT_PROXY_SYNC_PASSWORD@host.docker.internal:15432/postgres?sslmode=disable
#
# sslmode=disable korrekt: Postgres hat SSL=off; TLS-Verschlüsselung = Cloudflare Tunnel.
RAPT_PROXY_DATABASE_URL=postgres://proxy_sync:<RAPT_PROXY_SYNC_PASSWORD>@db-rapt:5432/postgres?sslmode=disable
RAPT_SYNC_ENABLED=true
#
# DEPRECATED Phase-1-Vars (nicht mehr von compose-Services referenziert):
# (kann nach nächstem encrypt-env.sh-Cleanup-Lauf entfernt werden)
# DATABASE_URL=postgres://proxy_sync:<RAPT_PROXY_SYNC_PASSWORD>@db-rapt:5432/postgres?sslmode=disable

# ─── Cloudflare Tunnel-TCP (Cross-VPS DB-Zugriff) ───────────────────────────
# Nur auf dem Proxy-VPS nötig (wenn api_proxy und supabase-db auf verschiedenen VPS).
# Service-Token aus Cloudflare Access Application für db-tcp.alexstuder.cloud.
# Setup: Cloudflare Dashboard → Access → Applications → Service Auth → Token anlegen.
# Dann: docker compose -f docker-compose.yml -f docker-compose.tunnel-tcp.yml \
#          --profile vps up -d cloudflared-access-tcp
DB_TCP_HOSTNAME=db-tcp.alexstuder.cloud
DB_TCP_LOCAL_PORT=15432
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ─── Portainer (Container-Uebersicht, Hub-and-Spoke) ─────────────────────────
# PORTAINER_ROLE steuert die Rolle dieses VPS beim Portainer-Bootstrap.
#   auto   = Probe gegen PORTAINER_SERVER_URL; Hub falls nicht erreichbar, Agent falls erreichbar.
#            Bei unklar (Timeout/mehrdeutig) → Abbruch mit Hinweis (kein Zweit-Hub-Schutz).
#   hub    = Dieser VPS errichtet/bleibt Hub (portainer CE Server + Volume portainer_data).
#   agent  = Dieser VPS startet Edge-Agent (pollt ausgehend zum Hub, kein Inbound-Port).
# Default: auto
PORTAINER_ROLE=auto

# PORTAINER_SERVER_URL: Hub-Endpoint fuer die auto-Probe + Agent-Verbindung.
# Auch als PORTAINER_EDGE_URL wird der edge.-Hostname benutzt (Port 8000).
# Aendern fuer andere Domain (z.B. alexstuder.ch nach DNS-Migration).
PORTAINER_SERVER_URL=https://portainer.alexstuder.cloud
PORTAINER_EDGE_URL=https://edge.alexstuder.cloud

# PORTAINER_EDGE_KEY: wiederverwendbarer Edge-Key (AEEC) fuer Auto-Join der Agents.
# CREDENTIAL-SCHRITT: wird nach dem ersten Hub-Bootstrap aus der Portainer-UI/API geholt.
# Ablauf:
#   1. Hub bootstrappen (PORTAINER_ROLE=hub) → portainer-Container laeuft.
#   2. Portainer-UI aufrufen (portainer.alexstuder.cloud), Admin-PW setzen.
#   3. Environments → Edge Environments → Add Environment → Edge Agent → AEEC-Key kopieren.
#   4. Wert hier eintragen → encrypt-env.sh → .env.gpg committen.
# Danach joinen Agents auf weiteren VPS automatisch (PORTAINER_ROLE=auto oder =agent).
PORTAINER_EDGE_KEY=

# PORTAINER_EDGE_ID: optionale feste Edge-ID fuer den Agent-Container.
# Leer lassen → Portainer generiert eine UUID pro Agent automatisch.
# Nur setzen wenn deterministische IDs in der Portainer-UI benoetigt werden.
PORTAINER_EDGE_ID=

# PORTAINER_ACCESS_EMAIL: E-Mail-Adresse, die in der Cloudflare Access Allow-Policy
# fuer portainer.alexstuder.cloud eingetragen wird.
# Nur auf dem Hub-VPS aktiv (PORTAINER_ROLE=hub); kein Effekt auf Agent-VPS.
# Login via Cloudflare One-Time-PIN (OTP) — kein externer IdP nötig.
# Default: alex@alexstuder.ch
PORTAINER_ACCESS_EMAIL=alex@alexstuder.ch

# ─── Mailserver (Poste.io) — nur auf dem Mail-VPS aktiv ──────────────────────
# Mail ist die bewusste Ausnahme zum Tunnel-Only-Prinzip (offene Inbound-Ports
# 25/465/587/143/993 + ungeproxytes A-Record + echtes Let's-Encrypt-Cert).
# Freigabe erteilt 2026-05-25. Siehe MULTIVPS_ARCHITEKTUR.md §2 / MAILSERVER.md.
#
# Aktivierung via bootstrap.sh-Menü → "Mailserver (Poste.io)".
# Marker: /etc/brewing/stateful-units.d/mail
# Backup: scripts/backup.sh (tar | gpg → backups/mail/poste_<TS>.tar.gpg)
# DNS:    scripts/cloudflare-reconcile.sh (MX/A-unproxied/SPF/DMARC, marker-gesteuert)
# Cert:   certbot DNS-01 via CLOUDFLARE_API_TOKEN (bootstrap._mail_provision_cert)
#
# MAIL_DOMAIN: Root-Domain für Mail (MX/A/SPF/DMARC-Records + Webmail-Subdomain).
# Default auf .cloud (Staging); .ch-Wechsel = reiner .env-Edit + encrypt-env.sh.
MAIL_DOMAIN=alexstuder.cloud
#
# MAIL_HOSTNAME: FQDN des Mailservers (= hostname im posteio-Container + A-Record-Name).
MAIL_HOSTNAME=mail.alexstuder.cloud
#
# POSTE_ADMIN_EMAIL: Erst-Admin der Poste.io-Verwaltung.
# Das Admin-Passwort wird NICHT hier gesetzt — es wird beim ersten UI-Login gesetzt
# (CREDENTIAL-SCHRITT): https://webmail.${MAIL_DOMAIN} → erster Login.
POSTE_ADMIN_EMAIL=admin@alexstuder.cloud
#
# MAIL_TLS_EMAIL: Kontakt-E-Mail für certbot Let's-Encrypt (DNS-01 via CF-API-Token).
# Leer → bootstrap leitet es automatisch aus POSTE_ADMIN_EMAIL ab.
MAIL_TLS_EMAIL=
#
# MAIL_VPS_IP: VPS-IP für das ungeproxyte A-Record mail.${MAIL_DOMAIN}.
# Leer (default) oder literal "auto" → Auto-Detect zur Reconcile-Laufzeit
#   (externes Echo: api.ipify.org → ifconfig.me → icanhazip.com → ifconfig.co;
#    + optionaler hcloud-Cross-Check wenn HCLOUD_TOKEN gesetzt und hcloud CLI vorhanden).
# Konkrete IPv4 (z.B. 1.2.3.4) → manueller Override — kein Echo, kein hcloud-Check.
#   Nützlich bei Floating-IPs oder mehreren NICs.
# Ungültiger Wert (z.B. "1.2.3") → Warnung auf stderr + Auto-Detect-Fallback;
#   A-Record wird nicht übersprungen, sondern per Echo-Kette aufgelöst.
# Auto-Detect erfordert Internet-Egress des VPS; hcloud-Cross-Check ist optional
#   (HCLOUD_TOKEN in .env.gpg + hcloud CLI auf dem VPS).
MAIL_VPS_IP=
#
# ── Postausgang-Relay / Smarthost (Brevo, Port 587) ─────────────────────────
# Anbieter-neutral konfiguriert; Defaults auf Brevo (festgelegter Anbieter, Entscheidung 5).
# SMTP_RELAY_PASSWORD ist ein echtes Secret — nur in .env/.env.gpg, nie plaintext committen.
# CREDENTIAL-SCHRITT: Brevo-Account → alexstuder.cloud als Versand-Domain authentifizieren
# (DKIM-CNAMEs ins Cloudflare-DNS; SPF-include=spf.brevo.com setzt reconcile).
SMTP_RELAY_HOST=smtp-relay.brevo.com
SMTP_RELAY_PORT=587
# USERNAME = BREVO_SMTP_USER (alex@alexstuder.ch). Echte Werte nur in .env/.env.gpg
# (CREDENTIAL-SCHRITT, aus dem Vorlagen-Repo übernommen — siehe MAILSERVER.md §Entscheidung 5).
SMTP_RELAY_USERNAME=
SMTP_RELAY_PASSWORD=
#
# MAIL_SPF_INCLUDE: SPF-include des Relays (autorisiert dessen Versand-IPs).
# Bei Brevo: spf.brevo.com. Leer → kein include: im SPF-Record (nur eigener MX).
MAIL_SPF_INCLUDE=spf.brevo.com
#
# MAIL_DKIM_TXT: Optionaler Poste.io-Eigen-DKIM-Key (für Direkt-/Lokalversand).
# Beim Relay-Versand signiert der Anbieter (Brevo) → dessen DKIM-Records (CNAME/TXT)
# beim Account-Setup einrichten (CREDENTIAL-SCHRITT).
# Poste.io generiert seinen Eigen-Key beim ersten Start unter poste-data/dkim/.
# Falls bootstrap._mail_configure_relay ihn nicht automatisch publiziert, hier eintragen
# → reconcile publiziert ihn als TXT-Record dkim._domainkey.${MAIL_DOMAIN}.
# Leer → nur Log-Hinweis ausgeben, kein Fehler.
MAIL_DKIM_TXT=
