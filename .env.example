# Docker Hub (für Compose image references)
DOCKERHUB_USERNAME=dein_dockerhub_username

# Cloudflare Tunnel (Token aus Zero Trust Dashboard)
CLOUDFLARE_TUNNEL_TOKEN=dein_tunnel_token

# RAPT API (User ID + API Key, nicht Email/Passwort)
RAPT_USER_ID=
RAPT_API_KEY=

# Brewfather API (User ID + API Key)
BREWFATHER_USER_ID=
BREWFATHER_API_KEY=

# OpenAI
OPENAI_API_KEY=sk-...
